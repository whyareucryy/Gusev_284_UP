@model Gusev284_UP.ViewModels.RawMaterialCalculateViewModel

@{
    ViewData["Title"] = "Расчёт количества сырья";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <!-- Заголовок с логотипом -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 style="font-family: 'Candara', sans-serif; color: #333;">@ViewData["Title"]</h1>
        <img src="~/images/logo.png" alt="Комфорт Мебель" style="height: 60px;" asp-append-version="true" />
    </div>

    <!-- Кнопка назад -->
    <div class="mb-3">
        <a href="@Url.Action("Index")" class="btn btn-accent">
            ← Назад к списку продукции
        </a>
    </div>

    <!-- Форма расчёта -->
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-secondary-light">
                    <h5 class="mb-0">Введите параметры расчёта</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Calculate" method="post">
                        @Html.AntiForgeryToken()

                        <!-- Тип продукции -->
                        <div class="mb-3">
                            <label asp-for="ProductTypeId" class="form-label">Тип продукции *</label>
                            <select asp-for="ProductTypeId" class="form-select" asp-items="ViewBag.ProductTypes">
                                <option value="">-- Выберите тип продукции --</option>
                            </select>
                            <span asp-validation-for="ProductTypeId" class="text-danger"></span>
                        </div>

                        <!-- Тип материала -->
                        <div class="mb-3">
                            <label asp-for="MaterialTypeId" class="form-label">Тип материала *</label>
                            <select asp-for="MaterialTypeId" class="form-select" asp-items="ViewBag.MaterialTypes">
                                <option value="">-- Выберите тип материала --</option>
                            </select>
                            <span asp-validation-for="MaterialTypeId" class="text-danger"></span>
                        </div>

                        <!-- Количество продукции -->
                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label">Количество продукции *</label>
                            <input asp-for="Quantity" class="form-control" type="number" min="1" step="1" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <!-- Параметр 1 -->
                        <div class="mb-3">
                            <label asp-for="Param1" class="form-label">Параметр 1 (например, длина) *</label>
                            <input asp-for="Param1" class="form-control" type="number" min="0.01" step="0.01" />
                            <span asp-validation-for="Param1" class="text-danger"></span>
                        </div>

                        <!-- Параметр 2 -->
                        <div class="mb-3">
                            <label asp-for="Param2" class="form-label">Параметр 2 (например, ширина) *</label>
                            <input asp-for="Param2" class="form-control" type="number" min="0.01" step="0.01" />
                            <span asp-validation-for="Param2" class="text-danger"></span>
                        </div>

                        <!-- Кнопка отправки -->
                        <button type="submit" class="btn btn-accent">
                            Рассчитать
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Блок с результатом -->
        @if (Model?.Result != null)
        {
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-secondary-light">
                        <h5 class="mb-0">Результат расчёта</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.Result == -1)
                        {
                            <div class="alert alert-danger">
                                <strong>Ошибка:</strong> Не удалось выполнить расчёт. Проверьте правильность введённых данных.
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-success">
                                <h4 class="alert-heading">Необходимое количество сырья:</h4>
                                <p class="display-4 text-center" style="color: #355CBD;">@Model.Result</p>
                                <p class="mb-0">единиц (с учётом потерь)</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}